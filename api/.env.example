# Copy to .env and fill in. docker compose reads .env automatically.

# --- Database ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=kupreu
MYSQL_USER=kupreu
MYSQL_PASSWORD=kupreu
MONGO_URI=mongodb://localhost:27017/kupreu

# --- Redis ---
# Leave empty for no password (dev). Set for prod.
REDIS_PASSWORD=

# --- JWT (REQUIRED) ---
# Generate: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRATION=86400000

# --- CORS ---
# Comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Set true for dev to expose Swagger UI (/swagger-ui). Keep false in prod.
SWAGGER_ENABLED=false
